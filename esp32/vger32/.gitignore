# PlatformIO build artifacts
.pio/
.pioenvs/
.piolibdeps/
*.d
*.o
*.elf
*.bin
*.map

# Generated by scripts/build.py — each build gets a unique version/timestamp
**/build_info.h

# IDE specific files
.idea/
.vscode/

# data folder — ignore contents, keep the folder tracked via .gitkeep
data/*
!data/.gitkeep

# Sensitive configuration files (keys, credentials, etc)
*.vger

# Environment variables
.env
.env.local

