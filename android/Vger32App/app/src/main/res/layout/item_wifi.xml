<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="@dimen/spacing_l"
    android:paddingEnd="@dimen/spacing_l"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="?attr/selectableItemBackground">

    <View
        android:id="@+id/view_signal"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/shape_status_dot" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txt_ssid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_size_xs"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/txt_bssid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_size_xs"
            android:textColor="@color/color600"
            android:fontFamily="monospace"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/txt_rssi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/text_size_xs"
        android:textStyle="bold"
        android:fontFamily="monospace" />

</LinearLayout>
