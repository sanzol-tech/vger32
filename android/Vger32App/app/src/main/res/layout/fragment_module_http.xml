<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color100">

    <include layout="@layout/header_module_selector" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="@dimen/spacing_l"
            android:paddingBottom="@dimen/spacing_l">

            <!-- ── WEB ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/spacing_xl"
                android:paddingEnd="@dimen/spacing_xl"
                android:paddingBottom="@dimen/spacing_s"
                android:text="@string/http_group_web"
                style="@style/SectionHeaderStyle" />

            <include layout="@layout/item_card_action" android:id="@+id/item_dashboard"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_l" android:layout_marginEnd="@dimen/spacing_l" android:layout_marginBottom="@dimen/spacing_m" />

            <!-- ── MONITOR ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/spacing_xl"
                android:paddingEnd="@dimen/spacing_xl"
                android:paddingTop="@dimen/spacing_s"
                android:paddingBottom="@dimen/spacing_s"
                android:text="@string/http_group_monitor"
                style="@style/SectionHeaderStyle" />

            <include layout="@layout/item_card_action" android:id="@+id/item_identity"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_l" android:layout_marginEnd="@dimen/spacing_l" android:layout_marginBottom="@dimen/spacing_m" />

            <include layout="@layout/item_card_action" android:id="@+id/item_metrics"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_l" android:layout_marginEnd="@dimen/spacing_l" android:layout_marginBottom="@dimen/spacing_m" />

            <include layout="@layout/item_card_action" android:id="@+id/item_sensors"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_l" android:layout_marginEnd="@dimen/spacing_l" android:layout_marginBottom="@dimen/spacing_m" />

            <include layout="@layout/item_card_action" android:id="@+id/item_boot_history"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_l" android:layout_marginEnd="@dimen/spacing_l" android:layout_marginBottom="@dimen/spacing_m" />

            <include layout="@layout/item_card_action" android:id="@+id/item_logs"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_l" android:layout_marginEnd="@dimen/spacing_l" android:layout_marginBottom="@dimen/spacing_m" />

            <!-- ── ACTIONS ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/spacing_xl"
                android:paddingEnd="@dimen/spacing_xl"
                android:paddingTop="@dimen/spacing_s"
                android:paddingBottom="@dimen/spacing_s"
                android:text="@string/http_group_actions"
                style="@style/SectionHeaderStyle" />

            <include layout="@layout/item_card_action" android:id="@+id/item_restart"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_l" android:layout_marginEnd="@dimen/spacing_l" android:layout_marginBottom="@dimen/spacing_m" />

            <include layout="@layout/item_card_action" android:id="@+id/item_force_ap"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_l" android:layout_marginEnd="@dimen/spacing_l" android:layout_marginBottom="@dimen/spacing_m" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>