<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/shape_bottom_sheet"
    android:paddingBottom="@dimen/spacing_l">

    <!-- Handle -->
    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="@dimen/spacing_m"
        android:background="@color/color400"
        android:backgroundTint="@color/color400" />

    <!-- Feed actions: module name left, copy and clear icon buttons right -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/spacing_l"
        android:paddingEnd="@dimen/spacing_m"
        android:paddingBottom="@dimen/spacing_s">

        <TextView
            android:id="@+id/txt_selected_module"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="@dimen/text_size_s"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:fontFamily="monospace"
            android:singleLine="true"
            android:ellipsize="end" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_copy_feed"
            style="@style/Widget.App.Button.OutlinedIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="@string/action_copy"
            app:icon="@drawable/ic_content_copy" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_clear_feed"
            style="@style/Widget.App.Button.OutlinedIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="@dimen/spacing_s"
            android:contentDescription="@string/action_clear_feed"
            app:icon="@drawable/ic_mop" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginBottom="@dimen/spacing_m"
        android:background="@color/separator" />

    <!-- Message input row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/spacing_l"
        android:paddingEnd="@dimen/spacing_l"
        android:paddingBottom="@dimen/spacing_m">

        <EditText
            android:id="@+id/edit_msg"
            style="@style/Widget.App.EditText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/spacing_s"
            android:hint="@string/hint_message"
            android:textSize="@dimen/text_size_xxs"
            android:inputType="text"
            android:imeOptions="actionSend"
            android:maxLines="1" />

        <Button
            android:id="@+id/btn_cmd_send"
            style="@style/Widget.App.Button.Outlined"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/btn_send"
            android:textSize="@dimen/text_size_xs" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginBottom="@dimen/spacing_m"
        android:background="@color/separator" />

    <!-- Commands grid — 2 columns -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:paddingStart="@dimen/spacing_m"
        android:paddingEnd="@dimen/spacing_m"
        android:useDefaultMargins="false">

        <Button
            android:id="@+id/btn_cmd_ping"
            style="@style/Widget.App.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:text="@string/cmd_ping"
            android:textSize="@dimen/text_size_xs" />

        <Button
            android:id="@+id/btn_cmd_publish_now"
            style="@style/Widget.App.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:text="@string/cmd_publish_now"
            android:textSize="@dimen/text_size_xs" />

        <Button
            android:id="@+id/btn_cmd_sleep"
            style="@style/Widget.App.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:text="@string/cmd_sleep"
            android:textSize="@dimen/text_size_xs" />

        <Button
            android:id="@+id/btn_cmd_force_ap"
            style="@style/Widget.App.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:text="@string/cmd_force_ap"
            android:textSize="@dimen/text_size_xs" />

        <Button
            android:id="@+id/btn_cmd_reboot"
            style="@style/Widget.App.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:text="@string/cmd_reboot"
            android:textSize="@dimen/text_size_xs" />

    </GridLayout>

</LinearLayout>