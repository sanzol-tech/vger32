<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    tools:context=".ui.MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp">

            <ImageView
                android:id="@+id/img_logo"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="end"
                android:scaleType="fitCenter"
                android:padding="@dimen/spacing_s"
                android:src="@drawable/ic_app_logo"
                android:importantForAccessibility="no" />

        </com.google.android.material.appbar.MaterialToolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <fragment
        android:id="@+id/nav_host_fragment_content_main"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:defaultNavHost="true"
        app:navGraph="@navigation/nav_graph" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/separator" />

    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/tab_modules"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/tab_modules_icon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_developer_board" />

            <TextView
                android:id="@+id/tab_modules_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/tab_modules"
                android:textSize="@dimen/text_size_xs" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/tab_mqtt"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/tab_mqtt_icon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_mqtt" />

            <TextView
                android:id="@+id/tab_mqtt_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/tab_mqtt"
                android:textSize="@dimen/text_size_xs" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/tab_http"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/tab_http_icon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_language" />

            <TextView
                android:id="@+id/tab_http_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/tab_http"
                android:textSize="@dimen/text_size_xs" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/tab_localizer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/tab_localizer_icon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_map" />

            <TextView
                android:id="@+id/tab_localizer_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/tab_localizer"
                android:textSize="@dimen/text_size_xs" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/tab_settings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/tab_settings_icon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_settings" />

            <TextView
                android:id="@+id/tab_settings_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/tab_system"
                android:textSize="@dimen/text_size_xs" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>