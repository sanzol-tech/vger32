<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:baselineAligned="false"
    android:paddingStart="@dimen/spacing_l"
    android:paddingEnd="@dimen/spacing_l"
    android:paddingTop="@dimen/spacing_s"
    android:paddingBottom="@dimen/spacing_xs">

    <EditText
        android:id="@+id/edit_sleep_value"
        style="@style/Widget.App.EditText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginEnd="@dimen/spacing_s"
        android:inputType="number"
        android:digits="0123456789"
        android:hint="@string/hint_sleep_value" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggle_sleep_unit"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        app:singleSelection="true"
        app:selectionRequired="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_unit_s"
            style="@style/Widget.App.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:text="@string/sleep_unit_s" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_unit_m"
            style="@style/Widget.App.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:checked="true"
            android:text="@string/sleep_unit_m" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_unit_h"
            style="@style/Widget.App.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:text="@string/sleep_unit_h" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

</LinearLayout>