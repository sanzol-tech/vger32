<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/shape_bottom_sheet"
    android:paddingBottom="@dimen/spacing_l">

    <!-- Handle -->
    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="6dp"
        android:background="@color/color400" />

    <TextView
        android:id="@+id/action_download"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/spacing_l"
        android:paddingEnd="@dimen/spacing_l"
        android:textSize="@dimen/text_size_m"
        android:textColor="?attr/colorOnSurface"
        android:background="?attr/selectableItemBackground"
        android:drawableStart="@drawable/ic_download"
        android:drawablePadding="@dimen/spacing_m"
        app:drawableTint="?attr/colorControlNormal"
        android:text="@string/action_import_from_module" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="@dimen/spacing_xs"
        android:layout_marginBottom="@dimen/spacing_xs"
        android:background="@color/separator" />

    <TextView
        android:id="@+id/action_select_waypoints"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/spacing_l"
        android:paddingEnd="@dimen/spacing_l"
        android:textSize="@dimen/text_size_m"
        android:textColor="?attr/colorOnSurface"
        android:background="?attr/selectableItemBackground"
        android:drawableStart="@drawable/ic_select_check_box"
        android:drawablePadding="@dimen/spacing_m"
        app:drawableTint="?attr/colorControlNormal"
        android:text="@string/action_select_waypoints" />

</LinearLayout>
