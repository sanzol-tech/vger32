<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/header_storage"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/spacing_l"
            android:paddingEnd="@dimen/spacing_s">

            <TextView
                android:id="@+id/txt_storage_header"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/text_size_s"
                android:textColor="@color/color600" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel_select"
                style="@style/Widget.App.Button.IconBorderless"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:contentDescription="@string/cancel"
                android:visibility="gone"
                app:icon="@drawable/ic_close"
                app:iconTint="?attr/colorControlNormal" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/separator" />

        <!-- Content -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_storage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingTop="@dimen/spacing_xs"
                android:paddingBottom="80dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/txt_empty_storage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="@string/localizer_empty_storage"
                android:textColor="@color/color600"
                android:textSize="@dimen/text_size_s" />

        </FrameLayout>

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_storage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/spacing_m"
        android:src="@drawable/ic_menu"
        app:backgroundTint="@color/brand300"
        app:tint="@color/color100" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>